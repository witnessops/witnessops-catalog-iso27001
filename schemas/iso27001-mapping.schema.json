{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/witnessops/witnessops-catalog-iso27001/schemas/iso27001-mapping.schema.json",
  "title": "WitnessOps ISO 27001 Mapping",
  "$defs": {
    "isoClauseEnum": {
      "type": "string",
      "enum": [
        "4.1",
        "4.2",
        "4.3",
        "5.2",
        "6.1.2",
        "6.1.3",
        "7.2",
        "7.3",
        "7.4",
        "7.5",
        "8.1",
        "8.2",
        "8.3",
        "9.1",
        "9.2",
        "9.3",
        "10.1",
        "10.2"
      ]
    },
    "ismsSurface": {
      "type": "string",
      "minLength": 1
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "clauses",
    "isms_surface"
  ],
  "properties": {
    "clauses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/isoClauseEnum"
      }
    },
    "isms_surface": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ismsSurface"
      }
    }
  }
}