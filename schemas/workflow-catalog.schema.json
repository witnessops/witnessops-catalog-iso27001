{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/witnessops/witnessops-catalog-iso27001/schemas/workflow-catalog.schema.json",
  "title": "WitnessOps ISO 27001 Workflow Catalog",
  "$defs": {
    "ownerEnum": {
      "type": "string",
      "enum": [
        "control_governance_owner",
        "corrective_action_owner",
        "internal_audit_owner",
        "isms_owner",
        "management_review_owner",
        "operations_assurance_owner",
        "people_assurance_owner",
        "performance_owner",
        "policy_owner",
        "risk_owner",
        "risk_treatment_owner"
      ]
    },
    "deadlineTypeEnum": {
      "type": "string",
      "enum": [
        "governance_reporting_cycle",
        "internal_gate",
        "internal_policy",
        "periodic_review",
        "program_cycle",
        "risk_based_review_cycle",
        "severity_based_internal_sla"
      ]
    }
  },
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "workflow_id",
      "workflow_name",
      "trigger",
      "owner",
      "deadline",
      "required_evidence",
      "status_states",
      "iso27001_mapping"
    ],
    "properties": {
      "workflow_id": {
        "type": "string",
        "pattern": "^ISO27001-[0-9]{3}$"
      },
      "workflow_name": {
        "type": "string",
        "minLength": 1
      },
      "trigger": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "owner": {
        "$ref": "#/$defs/ownerEnum"
      },
      "deadline": {
        "anyOf": [
          {
            "type": "null"
          },
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "$ref": "#/$defs/deadlineTypeEnum"
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "required_evidence": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "status_states": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "iso27001_mapping": {
        "$ref": "https://github.com/witnessops/witnessops-catalog-iso27001/schemas/iso27001-mapping.schema.json"
      }
    }
  }
}